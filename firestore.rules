rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user is updating their own record
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to check if user is an admin
    // In production, user roles are tracked in their profile document
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Nested subcollections rules (bookmarks, progress, history)
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Questions Collection rules
    match /questions/{questionId} {
      allow read: if true; // Anyone can read questions to practice
      allow write: if isAdmin();
    }

    // Chapters Collection rules
    match /chapters/{chapterId} {
      allow read: if true; // Anyone can read handbook chapters
      allow write: if isAdmin();
      
      match /{document=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // App config metadata rules
    match /appConfig/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
